{
  "name": "interior-ar-backend",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma --skip-generate",
    "prestart": "npm run prisma:generate && npm run prisma:push",
    "start": "node dist/main.js",
    "build": "node -e \"console.log('Skip build: using prebuilt dist/')\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@nestjs/bullmq": "10.2.3",
    "@nestjs/common": "10.4.22",
    "@nestjs/core": "10.4.22",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/platform-express": "10.4.22",
    "@prisma/client": "5.22.0",
    "bcrypt": "5.1.1",
    "bullmq": "5.70.1",
    "cookie-parser": "1.4.7",
    "ioredis": "5.9.3",
    "prisma": "5.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "stripe": "14.25.0"
  }
}