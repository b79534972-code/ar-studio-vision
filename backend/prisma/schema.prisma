// ============================================================
// Prisma Schema — Interior AR SaaS Platform
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
}

enum SubscriptionPlan {
  free
  basic
  advanced
  pro
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
}

model User {
  id                   String             @id @default(uuid())
  name                 String
  email                String             @unique
  passwordHash         String
  avatar               String?
  role                 Role               @default(user)

  subscriptionPlan     SubscriptionPlan   @default(free)
  subscriptionStatus   SubscriptionStatus @default(active)

  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  usage                UserUsage?

  rooms                Room[]
  layouts              Layout[]
  furnitureModels      FurnitureModel[]
  arSessions           ARSession[]

  auditLogs            AuditLog[]
}

model UserUsage {
  userId           String   @id
  modelsCount      Int      @default(0)
  layoutsCount     Int      @default(0)
  aiRequestsCount  Int      @default(0)
  arSessionsCount  Int      @default(0)

  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Room {
  id        String   @id @default(uuid())
  userId    String
  name      String

  width     Float?
  height    Float?
  depth     Float?

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  layouts   Layout[]
}

model Layout {
  id        String   @id @default(uuid())
  userId    String
  roomId    String

  name      String
  version   Int      @default(1)

  // objects stored as JSON
  // example:
  // [{modelId, position, rotation, scale}]
  objects   Json     @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  room      Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)

  versions  LayoutVersion[]
  sessions  ARSession[]
}

model LayoutVersion {
  id        String   @id @default(uuid())
  layoutId  String
  snapshot  Json

  createdAt DateTime @default(now())

  layout    Layout   @relation(fields: [layoutId], references: [id], onDelete: Cascade)
}

model FurnitureModel {
  id          String   @id @default(uuid())
  name        String
  category    String

  width       Float?
  height      Float?
  depth       Float?

  modelUrl    String
  textureUrl  String?

  createdBy   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [createdBy], references: [id])
}

model ARSession {
  id        String   @id @default(uuid())

  userId    String
  layoutId  String?

  device    String?
  startedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  layout    Layout?  @relation(fields: [layoutId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String

  action    String
  metadata  Json?

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}