// ============================================================
// Prisma Schema — Interior AR SaaS Platform
// Synced with frontend types: subscription.ts, editor.ts, roomStore.ts
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum Role {
  user
  admin
}

enum SubscriptionPlan {
  free
  basic
  advanced
  pro
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
}

enum FurnitureCategory {
  sofa
  chair
  table
  storage
  bed
  lamp
  plant
  rug
  shelf
}

enum FurnitureStyle {
  modern
  scandinavian
  minimalist
  industrial
  japanese
}

enum ModelFormat {
  glb
  gltf
  usdz
}

enum AIFeatureType {
  layout_suggest
  layout_optimize
  style_transform
  product_recommend
  budget_optimize
  photorealistic_render
  full_room_redesign
}

enum AIRequestStatus {
  pending
  processing
  completed
  failed
}

enum Currency {
  VND
  USD
}

enum PurchaseStatus {
  pending
  completed
  failed
  refunded
}

// ─── User & Auth ─────────────────────────────────────────────

model User {
  id                   String             @id @default(uuid())
  name                 String
  email                String             @unique
  passwordHash         String
  avatar               String?
  role                 Role               @default(user)

  subscriptionPlan     SubscriptionPlan   @default(free)
  subscriptionStatus   SubscriptionStatus @default(active)

  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  usage                UserUsage?
  rooms                Room[]
  layouts              Layout[]
  furnitureModels      FurnitureModel[]
  arSessions           ARSession[]
  aiRequests           AIRequest[]
  creditPurchases      CreditPurchase[]
  auditLogs            AuditLog[]

  @@index([email])
  @@index([stripeCustomerId])
}

// ─── Usage & Credits ─────────────────────────────────────────

model UserUsage {
  userId           String   @id
  modelsCount      Int      @default(0)
  layoutsCount     Int      @default(0)
  aiRequestsCount  Int      @default(0)
  arSessionsCount  Int      @default(0)

  // AI credit system (matches frontend UserUsage)
  aiCreditsUsed    Int      @default(0)
  aiCreditsTotal   Int      @default(5) // Free plan default

  // Daily credit reset tracking (Free plan resets every 24h)
  lastCreditReset  DateTime @default(now())

  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Credit Purchases (one-time buy, use until depleted) ─────

model CreditPurchase {
  id              String           @id @default(uuid())
  userId          String

  plan            SubscriptionPlan // which plan pack was purchased
  creditAmount    Int              // number of credits purchased
  priceAmount     Int              // price in smallest currency unit (cents/dong)
  currency        Currency         @default(VND)

  // Stripe payment tracking
  stripePaymentId String?          @unique
  stripeInvoiceId String?

  status          PurchaseStatus   @default(pending)

  purchasedAt     DateTime         @default(now())
  expiresAt       DateTime?        // credit validity window

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purchasedAt])
  @@index([stripePaymentId])
}

// ─── Room ────────────────────────────────────────────────────

model Room {
  id         String   @id @default(uuid())
  userId     String
  name       String

  // Dimensions in meters (matches RoomConfig)
  width      Float    @default(6)
  depth      Float    @default(5)
  height     Float    @default(2.8)

  // Room appearance (matches RoomConfig)
  wallColor  String   @default("#F5F5F4")
  floorColor String   @default("#D6D3D1")

  thumbnail  String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  layouts    Layout[]

  @@index([userId])
}

// ─── Layout & Versioning ─────────────────────────────────────

model Layout {
  id        String   @id @default(uuid())
  userId    String
  roomId    String
  name      String
  version   Int      @default(1)

  // PlacedObject[] as JSON
  // [{id, furnitureId, name, category, position:[x,y,z], rotation:[x,y,z], scale:[x,y,z], color, dimensions:{w,h,d}}]
  objects   Json     @default("[]")

  thumbnail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  room      Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  versions  LayoutVersion[]
  sessions  ARSession[]

  @@index([userId])
  @@index([roomId])
}

model LayoutVersion {
  id        String   @id @default(uuid())
  layoutId  String
  version   Int
  snapshot  Json

  createdAt DateTime @default(now())

  layout    Layout   @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@index([layoutId, version])
}

// ─── Furniture Models ────────────────────────────────────────

model FurnitureModel {
  id          String            @id @default(uuid())
  name        String
  category    FurnitureCategory
  style       FurnitureStyle    @default(modern)
  material    String            @default("Mixed")
  color       String            @default("#6B7280")

  // Dimensions in meters (matches FurnitureItem.dimensions)
  width       Float
  height      Float
  depth       Float

  // 3D model files (matches FurnitureItem.modelUrl / usdzUrl)
  modelUrl    String?           // .glb/.gltf for WebXR & Desktop viewer
  usdzUrl     String?           // .usdz for iOS AR Quick Look
  textureUrl  String?
  thumbnail   String?
  format      ModelFormat?

  // Tags for search/filter
  tags        String[]          @default([])
  favorited   Boolean           @default(false)

  // null = system/catalog item, set = user-uploaded
  createdBy   String?
  createdAt   DateTime          @default(now())

  user        User?             @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([style])
  @@index([createdBy])
}

// ─── AR Sessions ─────────────────────────────────────────────

model ARSession {
  id          String    @id @default(uuid())
  userId      String
  layoutId    String?

  device      String?   // e.g. "iPhone 15 Pro", "Android Chrome"
  engine      String?   // "webxr" | "quicklook" | "desktop_viewer"
  objectCount Int?      // number of objects in the scene

  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  durationMs  Int?      // calculated on session end

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  layout      Layout?   @relation(fields: [layoutId], references: [id])

  @@index([userId, startedAt])
  @@index([layoutId])
}

// ─── Audit Log ───────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // e.g. "room.create", "layout.save", "credit.purchase", "ai.request"
  metadata  Json?

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action])
}

// ─── AI Requests ─────────────────────────────────────────────

model AIRequest {
  id           String          @id @default(uuid())
  userId       String
  feature      AIFeatureType
  creditCost   Int
  status       AIRequestStatus @default(pending)

  // Input parameters (room config, style, budget, objects, etc.)
  input        Json            @default("{}")

  // AI output (suggestions, renders, recommendations, optimized layout)
  output       Json?

  // Linked room/layout context
  roomId       String?
  layoutId     String?

  // Performance tracking
  processingMs Int?
  errorMessage String?

  createdAt    DateTime        @default(now())
  completedAt  DateTime?

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([feature, status])
  @@index([roomId])
}
